#!/bin/bash

set -Eeuo pipefail

DEFAULT_REF="refs/_local-ignored"
REF="${GIT_IGNORE_REF:-$DEFAULT_REF}"

usage() {
    cat <<EOF
Usage: git-ignore-local <command> [args]

Commands:
    push                Capture current state to ignore
    reset               Delete captured state to ignore
    ls                  List files in the local ignore list
    show                Show local-ignored entry
    filter-clean        Filter for staging (used in gitconfig)
    filter-smudge       Filter for checkout (used in gitconfig)
    help                Show this help message

Environment variables:
    GIT_IGNORE_REF      ref for storing backup files
                           (default: $DEFAULT_REF)
EOF
}

_print() {
    echo "$@" >&2
}

filter_clean() {
    local path="$1"

    if ! git rev-parse --verify -q "${REF}"         > /dev/null || \
       ! git rev-parse --verify -q "${REF}:$path"   > /dev/null || \
       ! git rev-parse --verify -q "${REF}^1:$path" > /dev/null
    then
        cat
        exit 0
    fi

    local current=$(git hash-object -w --stdin)
    local captured=$(git rev-parse "$REF:$path")
    local original=$(git rev-parse "${REF}^1:$path")

    set +Ee
    git merge-file --object-id -p \
        -L local -L ignored -L original \
        "$current" "$captured" "$original"
    local status="$?"

    if [[ $status -gt 0 ]] ; then
        _print "WARN: Conflicts found in local-ignored files and worktree - manual resolution required"
    fi

    # exit $status
}

filter_smudge() {
    local path="$1"

    if ! git rev-parse --verify -q "${REF}"         > /dev/null || \
       ! git rev-parse --verify -q "${REF}:$path"   > /dev/null || \
       ! git rev-parse --verify -q "${REF}^1:$path" > /dev/null
    then
        cat
        exit 0
    fi

    local current=$(git hash-object -w --stdin)
    local captured=$(git rev-parse "$REF:$path")
    local original=$(git rev-parse "${REF}^1:$path")

    set +Ee
    git merge-file --object-id -p \
        -L local -L ignored -L original \
        "$captured" "$original" "$current"
    local status="$?"

    if [[ $status -gt 0 ]] ; then
        _print "WARN: local-ignored files conflict with worktree changes; the smudge filter generated conflicting content - manual resolution required"
    fi

    # exit $status
}

_push() {
    local captured=$(git stash create "local-ignored captured")

    git update-ref --create-reflog "$REF" "$captured"
    echo $captured
}

_show() {
    git stash show "$REF"
}

_reset() {
    if ! git show-ref --verify -q "$REF" ; then
        _print "No files ignored locally"
    fi
    local hash=$(git rev-parse "$REF")
    git update-ref -d "$REF"

    _print "Forget captured state: $hash"
}

list_files() {
    if ! git show-ref --verify -q "$REF" ; then
        _print "No local-ignored entries."
        exit 0
    fi

    # _print "Info: You need to set the 'filter' configs on gitattributes(5) for ignoreing these files."

    git diff --name-only "$REF"^- "$@"
}

_diff() {
    if ! git show-ref --verify -q "$REF" ; then
        _print "No local-ignored entries."
        exit 0
    fi

    git diff "$REF" "$@"
}

main() {
    if [ $# -eq 0 ]; then
        usage
        exit 1
    fi

    local command="$1"
    shift

    case "$command" in
        push)
            _push "$@"
            ;;
        reset)
            _reset "$@"
            ;;
        ls)
            list_files "$@"
            ;;
        # diff)
        #     _diff "$@"
        #     ;;
        show)
            _show "$@"
            ;;
        filter-clean)
            # specify '%f' in git config
            filter_clean "$@"
            ;;
        filter-smudge)
            # specify '%f' in git config
            filter_smudge "$@"
            ;;
        help|-h|--help)
            usage
            ;;
        *)
            echo "Error: Unknown command '$command'" >&2
            usage
            exit 1
            ;;
    esac
}

main "$@"
